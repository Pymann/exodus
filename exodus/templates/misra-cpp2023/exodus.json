{
    "$schema": "exodus.project.config-1.0",
    "name": "misra-cpp2023",
    "version": "1.0.0",
    "description": "Template project to trigger MISRA C++:2023 violations",
    "apt_packages": [
        {
            "name": "libclang1-20",
            "version": "1:20.1.2-0ubuntu1~24.04.2",
            "arch": "amd64",
            "required": true,
            "digest": null
        }
    ],
    "output_type": "executable",
    "misra_profile": "cpp2023",
    "clang_library_file": "__exodus_cache/apt/libclang1-20/amd64/1:20.1.2-0ubuntu1~24.04.2/payload/usr/lib/x86_64-linux-gnu/libclang-20.so.20",
    "misra_heuristics": {
        "rule_2_10_1": {
            "enabled": true,
            "suppressions": [],
            "min_identifier_length": 3,
            "case_insensitive": true,
            "confusable_groups": [
                "o0",
                "il1",
                "s5",
                "z2",
                "b8",
                "g6",
                "q9"
            ]
        },
        "rule_20_9": {
            "enabled": true,
            "suppressions": [],
            "allowed_undefined_macros": [
                "_MSC_VER",
                "_CRT_SECURE_NO_DEPRECATE",
                "__GNUC__",
                "__GNUC_MINOR__",
                "__GNUC_PATCHLEVEL__",
                "__clang__",
                "__clang_major__",
                "__clang_minor__",
                "__clang_patchlevel__",
                "__STDC__",
                "__STDC_VERSION__",
                "__STDC_HOSTED__",
                "__cplusplus",
                "__has_include",
                "__has_feature",
                "__has_extension",
                "__has_builtin"
            ]
        }
    },
    "sources": [
        "src/**/*.cpp",
        "src/**/*.cc",
        "src/**/*.cxx"
    ]
}
